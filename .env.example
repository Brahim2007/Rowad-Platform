# Database (PostgreSQL)
# Use the provider's pooled/PgBouncer connection URL, not the direct database URL.
# Supabase: use the transaction/session pooler host and port.
# Prisma Data Platform/db.prisma.io: keep pgbouncer=true.
ROWAD_DATABASE_URL="postgresql://USER:PASSWORD@POOLER_HOST:5432/rowad_platform?sslmode=require&pgbouncer=true&connection_limit=5&pool_timeout=30"

# Auth
# Generate secret: openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3002"
AUTH_TRUST_HOST=true

# لا تفعّلها إلا إذا كان التطبيق خلف reverse proxy موثوق يحذف رؤوس العميل الأصلية.
TRUST_PROXY_IP_HEADERS=false
# فعّلها فقط عند المرور المباشر عبر Cloudflare.
TRUST_CLOUDFLARE_IP=false

# Development-only admin fallback. Ignored outside NODE_ENV=development.
# DEV_ADMIN_EMAIL="dev-admin@example.test"
# DEV_ADMIN_PASSWORD="replace-with-a-local-only-password"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3002"

# Gemini AI (server-side only)
# Create a fresh key in Google AI Studio, then configure it in Vercel Environment Variables.
# Never commit the real key. The default model supports Arabic and structured JSON reports.
GEMINI_API_KEY=""
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
GEMINI_MODEL="gemini-3.5-flash"
# Keep both at zero on the free tier. Set current paid prices only after enabling billing.
GEMINI_INPUT_PRICE_PER_MILLION="0"
GEMINI_OUTPUT_PRICE_PER_MILLION="0"
AI_MONTHLY_BUDGET="5.00"
# مخفي افتراضيًا؛ يمكن إعادته لاحقًا دون تعديل الكود.
NEXT_PUBLIC_SHOW_AI_USAGE_BALANCE="false"

# Optional: one shared Gmail sender for all platform managers.
# Turn on Google 2-Step Verification, then use a 16-character App Password.
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="rowad.notifications@gmail.com"
# SMTP_PASS="google-app-password"
# EMAIL_FROM="rowad.notifications@gmail.com"

# Optional: Gmail API read access for the future admin inbox sync.
# Requires OAuth consent with the gmail.readonly scope; never commit these values.
# GMAIL_CLIENT_ID=""
# GMAIL_CLIENT_SECRET=""
# GMAIL_REFRESH_TOKEN=""
# GMAIL_ACCOUNT="rowad.notifications@gmail.com"
