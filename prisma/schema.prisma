generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("ROWAD_DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════
// الشركاء والداعمون (Partners & Sponsors)
// ═══════════════════════════════════════════════════════════

model Partner {
  id          String      @id @default(cuid())
  name        String      @db.VarChar(255)
  slug        String      @unique @db.VarChar(255)
  logo        String?     @db.VarChar(500)
  websiteUrl  String?     @db.VarChar(500)
  type        PartnerType @default(PARTNER)
  description String?     @db.Text
  sortOrder   Int         @default(0)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([type])
  @@index([isActive])
  @@index([isActive, sortOrder])
  @@map("partners")
}

enum PartnerType {
  PARTNER // شريك
  SPONSOR // راعي
  SUPPORTER // داعم
  DONOR // مانح
}

// ═══════════════════════════════════════════════════════════
// المستفيدون والأعضاء (Beneficiaries & Members)
// ═══════════════════════════════════════════════════════════

enum MemberType {
  BENEFICIARY
  TEAM
  BOTH
}

model Beneficiary {
  id             String            @id @default(cuid())
  code           String            @unique @db.VarChar(50)
  firstName      String            @db.VarChar(100)
  lastName       String            @db.VarChar(100)
  email          String?           @unique @db.VarChar(255)
  phone          String?           @db.VarChar(50)
  gender         Gender?
  birthDate      DateTime?
  nationality    String?           @db.VarChar(100)
  country        String?           @db.VarChar(100)
  city           String?           @db.VarChar(100)
  educationLevel EducationLevel?
  bio            String?           @db.Text
  avatar         String?           @db.VarChar(500)
  status         BeneficiaryStatus @default(ACTIVE)
  registeredAt   DateTime          @default(now())
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  // ─── الحقول الموحّدة (Unified Member fields) ───
  type        MemberType @default(BENEFICIARY)
  role        String?    @db.VarChar(200)
  slug        String?    @unique @db.VarChar(255)
  linkedinUrl String?    @db.VarChar(500)
  memberSince DateTime?
  sortOrder   Int        @default(0)
  interests   String?    @db.Text // JSON: تحليل الاهتمامات

  // ─── حقول نظام «لوحة أثر الرواد» (Impact Dashboard) ───
  networkRole String?   @db.VarChar(200) // الصفة داخل الشبكة: باحث ومفكر، مؤثر رقمي...
  joinDate    DateTime? // تاريخ الانضمام للشبكة
  impactNote  String?   @db.Text // ملاحظات خاصة بلوحة الأثر

  // ─── بوابة العضو (Member Portal) ───
  passwordHash       String? @db.VarChar(255) // كلمة مرور بوابة العضو
  mustChangePassword Boolean @default(true) // يُلزم بتغيير كلمة المرور عند أول دخول

  // ─── ربط العضو بمنصة (للإدارة المباشرة) ───
  platformId String?
  platform   Platform? @relation("MemberPlatform", fields: [platformId], references: [id], onDelete: SetNull)

  enrollments              Enrollment[]
  participations           Participation[]
  beneficiaryJourneyStages BeneficiaryJourneyStage[]
  impactLogs               ImpactLog[]
  impactAwards             ImpactAward[]
  impactGates              ImpactGate[]

  @@index([code])
  @@index([email])
  @@index([status])
  @@index([type])
  @@index([country])
  @@index([firstName, lastName])
  @@index([status, registeredAt])
  @@index([status, type])
  @@index([type, sortOrder, registeredAt])
  @@index([status, type, sortOrder, registeredAt])
  @@index([platformId, status, type])
  @@map("beneficiaries")
}

enum Gender {
  MALE
  FEMALE
}

enum EducationLevel {
  HIGH_SCHOOL
  DIPLOMA
  BACHELOR
  MASTER
  DOCTORATE
  OTHER
}

enum BeneficiaryStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ═══════════════════════════════════════════════════════════
// المشاريع (Projects)
// ═══════════════════════════════════════════════════════════

model Project {
  id           String        @id @default(cuid())
  title        String        @db.VarChar(255)
  slug         String        @unique @db.VarChar(255)
  description  String        @db.Text
  fullContent  String?       @db.Text
  category     String        @db.VarChar(100)
  status       ProjectStatus @default(ACTIVE)
  coverImage   String?       @db.VarChar(500)
  startDate    DateTime?
  endDate      DateTime?
  partnerLogos String?       @db.Text
  isFeatured   Boolean       @default(false)
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  platformId String?
  platform   Platform? @relation(fields: [platformId], references: [id], onDelete: SetNull)

  programId String?
  program   Program? @relation(fields: [programId], references: [id], onDelete: SetNull)

  knowledgeItems   KnowledgeItem[]
  submittedReports SubmittedReport[]
  evaluations      Evaluation[]

  @@index([slug])
  @@index([category])
  @@index([status])
  @@index([isFeatured])
  @@index([platformId])
  @@index([programId])
  @@index([status, sortOrder])
  @@index([isFeatured, sortOrder])
  @@map("projects")
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
  PLANNING
}

// ═══════════════════════════════════════════════════════════
// المنصات (Platforms) ← برامج (Programs) ← أنشطة (Activities)
// ═══════════════════════════════════════════════════════════

model Platform {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(255)
  description String   @db.Text
  vision      String?  @db.Text
  logo        String?  @db.VarChar(500)
  coverImage  String?  @db.VarChar(500)
  color       String?  @db.VarChar(50)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  programs           Program[]
  projects           Project[]
  knowledgeItems     KnowledgeItem[]
  submittedReports   SubmittedReport[]
  platformIndicators PlatformIndicator[]
  coordinationTasks  CoordinationTask[]
  evaluations        Evaluation[]
  impactLogs         ImpactLog[]
  members            Beneficiary[]               @relation("MemberPlatform")
  adminUsers         AdminUser[]
  managerAssignments PlatformManagerAssignment[]
  documents          Document[]

  @@index([slug])
  @@index([isActive])
  @@index([isActive, sortOrder])
  @@map("platforms")
}

model Program {
  id               String    @id @default(cuid())
  name             String    @db.VarChar(255)
  slug             String    @unique @db.VarChar(255)
  description      String    @db.Text
  icon             String?   @db.VarChar(500)
  image            String?   @db.VarChar(500)
  startDate        DateTime?
  endDate          DateTime?
  maxBeneficiaries Int?
  sortOrder        Int       @default(0)
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  platformId String
  platform   Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  activities        Activity[]
  enrollments       Enrollment[]
  projects          Project[]
  knowledgeItems    KnowledgeItem[]
  submittedReports  SubmittedReport[]
  programIndicators ProgramIndicator[]
  coordinationTasks CoordinationTask[]
  evaluations       Evaluation[]
  impactLogs        ImpactLog[]

  @@index([slug])
  @@index([platformId])
  @@index([isActive])
  @@index([platformId, isActive, sortOrder])
  @@map("programs")
}

model Activity {
  id              String       @id @default(cuid())
  name            String       @db.VarChar(255)
  slug            String       @unique @db.VarChar(255)
  description     String       @db.Text
  type            ActivityType @default(WORKSHOP)
  icon            String?      @db.VarChar(500)
  location        String?      @db.VarChar(500)
  isOnline        Boolean      @default(false)
  startDate       DateTime?
  endDate         DateTime?
  maxParticipants Int?
  sortOrder       Int          @default(0)
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  programId String
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  participations Participation[]
  evaluations    Evaluation[]
  impactLogs     ImpactLog[]

  @@index([slug])
  @@index([programId])
  @@index([isActive])
  @@index([type])
  @@index([programId, isActive, sortOrder])
  @@map("activities")
}

enum ActivityType {
  WORKSHOP // ورشة عمل
  BOOTCAMP // معسكر تدريبي
  HACKATHON // هاكاثون
  SEMINAR // ندوة
  COMPETITION // مسابقة
  MENTORING // إرشاد
  COURSE // دورة
  EVENT // فعالية
  OTHER
}

// ═══════════════════════════════════════════════════════════
// التسجيل في البرامج (Enrollments)
// ═══════════════════════════════════════════════════════════

model Enrollment {
  id          String           @id @default(cuid())
  status      EnrollmentStatus @default(PENDING)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?
  notes       String?          @db.Text
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  beneficiaryId String
  beneficiary   Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)

  programId String
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  participations Participation[]
  impactLogs     ImpactLog[]

  @@unique([beneficiaryId, programId])
  @@index([beneficiaryId])
  @@index([programId])
  @@index([status])
  @@index([beneficiaryId, status])
  @@index([status, completedAt])
  @@map("enrollments")
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  COMPLETED
  DROPPED
  REJECTED
}

// ═══════════════════════════════════════════════════════════
// المشاركة في الأنشطة (Participations)
// ═══════════════════════════════════════════════════════════

model Participation {
  id             String              @id @default(cuid())
  status         ParticipationStatus @default(REGISTERED)
  attendedAt     DateTime?
  score          Float?
  feedback       String?             @db.Text
  certificateUrl String?             @db.VarChar(500)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  beneficiaryId String
  beneficiary   Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)

  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  enrollmentId String?
  enrollment   Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)

  impactLogs ImpactLog[]

  @@unique([beneficiaryId, activityId])
  @@index([beneficiaryId])
  @@index([activityId])
  @@index([enrollmentId])
  @@index([status])
  @@index([beneficiaryId, status])
  @@index([status, attendedAt])
  @@map("participations")
}

enum ParticipationStatus {
  REGISTERED // مسجّل
  ATTENDED // حضر
  COMPLETED // أتمّ
  ABSENT // غائب
  CANCELLED // ملغى
}

// ═══════════════════════════════════════════════════════════
// رسائل التواصل (Contact Messages)
// ═══════════════════════════════════════════════════════════

model ContactMessage {
  id        String    @id @default(cuid())
  name      String    @db.VarChar(200)
  email     String    @db.VarChar(255)
  subject   String    @db.VarChar(500)
  message   String    @db.Text
  isRead    Boolean   @default(false)
  repliedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([isRead])
  @@index([createdAt])
  @@map("contact_messages")
}

// ═══════════════════════════════════════════════════════════
// صفحات المحتوى (Content Pages)
// ═══════════════════════════════════════════════════════════

model ContentPage {
  id          String   @id @default(cuid())
  title       String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(255)
  content     String   @db.Text
  metaDesc    String?  @db.VarChar(300)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([isPublished])
  @@map("content_pages")
}

// ═══════════════════════════════════════════════════════════
// الأخبار والتحديثات (News Posts)
// ═══════════════════════════════════════════════════════════

model NewsPost {
  id          String    @id @default(cuid())
  title       String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(255)
  excerpt     String?   @db.Text
  content     String    @db.Text
  coverImage  String?   @db.VarChar(500)
  category    String?   @db.VarChar(100)
  tags        String?   @db.Text
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([isPublished])
  @@index([publishedAt])
  @@index([category])
  @@map("news_posts")
}

// ═══════════════════════════════════════════════════════════
// مستخدمو الإدارة (Admin Users)
// ═══════════════════════════════════════════════════════════

model AdminUser {
  id                         String                      @id @default(cuid())
  email                      String                      @unique @db.VarChar(255)
  passwordHash               String                      @db.VarChar(255)
  fullName                   String                      @db.VarChar(200)
  role                       AdminRole                   @default(EDITOR)
  isActive                   Boolean                     @default(true)
  lastLoginAt                DateTime?
  platformId                 String? // FK إلى Platform — مطلوب لدور PLATFORM_MANAGER
  platform                   Platform?                   @relation(fields: [platformId], references: [id], onDelete: SetNull)
  platformManagerAssignments PlatformManagerAssignment[]
  evaluationsCreated         Evaluation[]                @relation("EvaluationCreator")
  evaluationsAssigned        Evaluation[]                @relation("EvaluationEvaluator")
  evaluationsApproved        Evaluation[]                @relation("EvaluationApprover")
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt

  @@index([email])
  @@index([role])
  @@index([platformId])
  @@map("admin_users")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  PLATFORM_MANAGER
  EVALUATOR
}

model PlatformManagerAssignment {
  id             String                        @id @default(cuid())
  platformId     String
  platform       Platform                      @relation(fields: [platformId], references: [id], onDelete: Cascade)
  adminUserId    String
  adminUser      AdminUser                     @relation(fields: [adminUserId], references: [id], onDelete: Restrict)
  assignmentRole PlatformManagerAssignmentRole @default(PRIMARY)
  startedAt      DateTime                      @default(now())
  endedAt        DateTime?
  assignedBy     String?                       @db.VarChar(200)
  note           String?                       @db.Text
  createdAt      DateTime                      @default(now())
  updatedAt      DateTime                      @updatedAt

  @@index([platformId, endedAt])
  @@index([adminUserId, endedAt])
  @@index([assignmentRole])
  @@map("platform_manager_assignments")
}

enum PlatformManagerAssignmentRole {
  PRIMARY
  DEPUTY
}

// ═══════════════════════════════════════════════════════════
// الأرشيف والوثائق (Document Archive)
// ═══════════════════════════════════════════════════════════

model Document {
  id           String       @id @default(cuid())
  title        String       @db.VarChar(500)
  type         DocumentType @default(OTHER)
  description  String?      @db.Text
  content      String?      @db.Text
  tags         String?      @db.VarChar(500) // وسوم مفصولة بفواصل
  source       String       @default("PLATFORM_OUTPUT") @db.VarChar(50)
  sourceId     String?      @db.VarChar(100)
  periodYear   Int?
  periodMonth  Int? // 1-12
  fileUrl      String?      @db.VarChar(1000) // رابط الملف المرفوع
  fileType     String?      @db.VarChar(50) // pdf, docx, xlsx, image, etc.
  fileSize     Int? // الحجم بالبايت
  platformId   String?
  platform     Platform?    @relation(fields: [platformId], references: [id], onDelete: SetNull)
  uploadedBy   String?      @db.VarChar(200) // اسم الرافع
  uploadedById String? // معرف المستخدم الرافع
  lastEditedBy String?      @db.VarChar(200) // آخر من عدّل
  lastEditedAt DateTime?
  status       DocStatus    @default(DRAFT)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  versions DocumentVersion[]

  @@unique([source, sourceId])
  @@index([platformId])
  @@index([type])
  @@index([status])
  @@index([source])
  @@index([createdAt])
  @@index([periodYear, periodMonth])
  @@map("documents")
}

model DocumentVersion {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version    Int      @default(1)
  fileUrl    String   @db.VarChar(1000)
  editedBy   String?  @db.VarChar(200)
  editedAt   DateTime @default(now())
  changeNote String?  @db.Text

  @@index([documentId])
  @@map("document_versions")
}

enum DocumentType {
  REPORT // تقرير
  BUDGET // ميزانية
  FINANCIAL_STATEMENT // بيان أو كشف مالي
  MEETING_MINUTES // محضر اجتماع
  DECISION // قرار
  POLICY // سياسة أو لائحة
  CONTRACT // عقد أو اتفاقية
  WORK_PLAN // خطة عمل
  RESEARCH // بحث أو دراسة
  MANUAL // دليل
  TOOLKIT // حقيبة أدوات
  LESSON_LEARNED // درس مستفاد
  BEST_PRACTICE // ممارسة مثلى
  PRESENTATION // عرض تقديمي
  CORRESPONDENCE // مراسلة رسمية
  MEDIA // مادة مرئية أو مسموعة
  ANNOUNCEMENT // إعلان
  NEWSLETTER // نشرة
  OTHER // أخرى
}

enum DocStatus {
  DRAFT
  APPROVED
  ARCHIVED
}

// ═══════════════════════════════════════════════════════════
// الإشعارات الداخلية (Notification Center)
// ═══════════════════════════════════════════════════════════

model Notification {
  id            String    @id @default(cuid())
  recipientId   String    @db.VarChar(100) // member/beneficiary id or admin id
  recipientType String    @db.VarChar(50) // ADMIN | PLATFORM_MANAGER | MEMBER
  type          String    @db.VarChar(50) // ACTIVITY_APPROVED | ACTIVITY_REJECTED | NEW_SUBMISSION | BROADCAST | SYSTEM_ALERT
  title         String    @db.VarChar(500)
  body          String    @db.Text
  link          String?   @db.VarChar(500) // رابط للانتقال إليه
  isRead        Boolean   @default(false)
  readAt        DateTime?
  createdAt     DateTime  @default(now())
  expiresAt     DateTime?
  senderId      String?   @db.VarChar(100)
  senderName    String?   @db.VarChar(200)

  @@index([recipientId])
  @@index([recipientId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model Broadcast {
  id               String    @id @default(cuid())
  senderId         String    @db.VarChar(100)
  senderName       String?   @db.VarChar(200)
  targetType       String    @db.VarChar(50) // ALL | PLATFORM | ROLE | INDIVIDUAL
  targetPlatformId String? // للمنصة المعنية
  targetRole       String?   @db.VarChar(200) // للصفة المعنية
  targetMemberId   String? // للعضو المعني
  subject          String    @db.VarChar(500)
  body             String    @db.Text
  channel          String    @default("IN_APP") @db.VarChar(20) // IN_APP | EMAIL | BOTH
  status           String    @default("DRAFT") @db.VarChar(20) // DRAFT | SCHEDULED | SENT
  scheduledAt      DateTime?
  sentAt           DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([senderId])
  @@index([status])
  @@index([createdAt])
  @@map("broadcasts")
}

// ═══════════════════════════════════════════════════════════
// سجل استهلاك الذكاء الاصطناعي (AI Usage Log)
// ═══════════════════════════════════════════════════════════

model AiUsageLog {
  id           String   @id @default(cuid())
  userId       String // من استخدم
  feature      String   @db.VarChar(100) // report-summary, report-analysis, assistant
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costEstimate Float    @default(0)
  success      Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([feature])
  @@index([createdAt])
  @@map("ai_usage_logs")
}

model AiGeneratedReport {
  id                 String   @id @default(cuid())
  title              String   @db.VarChar(300)
  periodType         String   @db.VarChar(20)
  periodYear         Int
  periodMonth        Int?
  platformId         String?  @db.VarChar(100)
  monthlyPlatformKey String?  @unique @db.VarChar(150)
  networkRole        String?  @db.VarChar(200)
  reportJson         String   @db.Text
  metricsJson        String   @db.Text
  generatedBy        String   @db.VarChar(200)
  createdAt          DateTime @default(now())

  @@index([createdAt])
  @@index([generatedBy, createdAt])
  @@index([periodYear, periodMonth])
  @@index([platformId, periodYear, periodMonth])
  @@map("ai_generated_reports")
}

model AiGovernanceRecommendation {
  id               String    @id @default(cuid())
  fingerprint      String    @unique @db.VarChar(100)
  category         String    @db.VarChar(50)
  severity         String    @db.VarChar(20)
  title            String    @db.VarChar(300)
  summary          String    @db.Text
  evidence         String    @db.Text
  proposedAction   String    @db.Text
  platformId       String?   @db.VarChar(100)
  subjectType      String?   @db.VarChar(50)
  subjectId        String?   @db.VarChar(100)
  subjectName      String?   @db.VarChar(300)
  status           String    @default("DRAFT") @db.VarChar(20)
  aiEnhanced       Boolean   @default(false)
  generatedBy      String    @db.VarChar(200)
  reviewedBy       String?   @db.VarChar(200)
  reviewedAt       DateTime?
  reviewNote       String?   @db.Text
  actionType       String?   @db.VarChar(30)
  actionTargetId   String?   @db.VarChar(100)
  actionTargetName String?   @db.VarChar(300)
  actionedBy       String?   @db.VarChar(200)
  actionedAt       DateTime?
  actionMetadata   String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([category, status])
  @@index([platformId, status])
  @@index([subjectType, subjectId])
  @@index([actionType, actionedAt])
  @@map("ai_governance_recommendations")
}

// ═══════════════════════════════════════════════════════════
// إعدادات الموقع (Site Settings)
// ═══════════════════════════════════════════════════════════

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique @db.VarChar(100)
  value String @db.Text

  @@map("site_settings")
}

// ═══════════════════════════════════════════════════════════
// Webhooks (نقاط التكامل الخارجي)
// ═══════════════════════════════════════════════════════════

model Webhook {
  id              String    @id @default(cuid())
  name            String    @db.VarChar(255)
  url             String    @db.VarChar(1000)
  events          String    @db.Text
  secret          String?   @db.VarChar(255)
  isActive        Boolean   @default(true)
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  webhookLogs WebhookLog[]

  @@index([isActive])
  @@map("webhooks")
}

model WebhookLog {
  id         String   @id @default(cuid())
  webhookId  String
  webhook    Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event      String   @db.VarChar(255)
  payload    String?  @db.Text
  statusCode Int?
  success    Boolean  @default(false)
  error      String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([webhookId])
  @@index([createdAt])
  @@map("webhook_logs")
}

// ═══════════════════════════════════════════════════════════
// المكتبة المعرفية (Knowledge Library)
// ═══════════════════════════════════════════════════════════

model KnowledgeItem {
  id            String            @id @default(cuid())
  title         String            @db.VarChar(500)
  slug          String            @unique @db.VarChar(255)
  description   String?           @db.Text
  content       String?           @db.Text
  category      KnowledgeCategory @default(REPORT)
  type          KnowledgeType     @default(DOCUMENT)
  fileUrl       String?           @db.VarChar(1000)
  thumbnailUrl  String?           @db.VarChar(1000)
  tags          String?           @db.Text
  author        String?           @db.VarChar(200)
  language      String            @default("ar") @db.VarChar(10)
  viewCount     Int               @default(0)
  downloadCount Int               @default(0)
  isPublished   Boolean           @default(false)
  publishedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  platformId String?
  platform   Platform? @relation(fields: [platformId], references: [id], onDelete: SetNull)
  programId  String?
  program    Program?  @relation(fields: [programId], references: [id], onDelete: SetNull)
  projectId  String?
  project    Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([slug])
  @@index([category])
  @@index([type])
  @@index([isPublished])
  @@index([platformId])
  @@index([programId])
  @@index([projectId])
  @@map("knowledge_library")
}

enum KnowledgeCategory {
  REPORT // تقرير
  RESEARCH // بحث
  MANUAL // دليل
  TOOLKIT // حقيبة أدوات
  LESSON // درس مستفاد
  BEST_PRACTICE // ممارسة مثلى
  OTHER
}

enum KnowledgeType {
  DOCUMENT // مستند
  VIDEO // فيديو
  AUDIO // صوتي
  IMAGE // صورة
  PRESENTATION // عرض تقديمي
  SPREADSHEET // جدول بيانات
  LINK // رابط
  OTHER
}

// ═══════════════════════════════════════════════════════════
// قوالب التقارير والتقارير المرفوعة (Reports)
// ═══════════════════════════════════════════════════════════

model ReportTemplate {
  id          String   @id @default(cuid())
  title       String   @db.VarChar(500)
  slug        String   @unique @db.VarChar(255)
  description String?  @db.Text
  category    String   @db.VarChar(100)
  sections    String   @db.Text // JSON: [{title, type, required, options}]
  icon        String?  @db.VarChar(100)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reports SubmittedReport[]

  @@index([slug])
  @@index([category])
  @@index([isActive])
  @@map("report_templates")
}

model SubmittedReport {
  id          String         @id @default(cuid())
  templateId  String
  template    ReportTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  data        String         @db.Text // JSON: {sectionKey: value}
  status      ReportStatus   @default(DRAFT)
  submittedBy String?        @db.VarChar(200)
  reviewedBy  String?        @db.VarChar(200)
  reviewNotes String?        @db.Text
  submittedAt DateTime?
  reviewedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  platformId String?
  platform   Platform? @relation(fields: [platformId], references: [id], onDelete: SetNull)
  programId  String?
  program    Program?  @relation(fields: [programId], references: [id], onDelete: SetNull)
  projectId  String?
  project    Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  impactLogs ImpactLog[]

  @@index([templateId])
  @@index([status])
  @@index([platformId])
  @@index([programId])
  @@index([projectId])
  @@map("submitted_reports")
}

enum ReportStatus {
  DRAFT // مسودة
  SUBMITTED // مرفوع
  REVIEWED // مراجع
  APPROVED // معتمد
  REJECTED // مرفوض
}

// ═══════════════════════════════════════════════════════════
// التحليلات والمؤشرات (Analytics & KPIs)
// ═══════════════════════════════════════════════════════════

model PlatformIndicator {
  id            String   @id @default(cuid())
  platformId    String
  platform      Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)
  indicatorKey  String   @db.VarChar(100)
  indicatorName String   @db.VarChar(255)
  value         Float    @default(0)
  target        Float?
  unit          String?  @db.VarChar(50)
  period        String   @default("monthly") @db.VarChar(50) // monthly, quarterly, yearly
  recordedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  @@unique([platformId, indicatorKey, recordedAt])
  @@index([platformId])
  @@index([indicatorKey])
  @@map("platform_indicators")
}

model ProgramIndicator {
  id            String   @id @default(cuid())
  programId     String
  program       Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  indicatorKey  String   @db.VarChar(100)
  indicatorName String   @db.VarChar(255)
  value         Float    @default(0)
  target        Float?
  unit          String?  @db.VarChar(50)
  period        String   @default("monthly") @db.VarChar(50)
  recordedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  @@unique([programId, indicatorKey, recordedAt])
  @@index([programId])
  @@index([indicatorKey])
  @@map("program_indicators")
}

model AnalyticsSnapshot {
  id          String   @id @default(cuid())
  title       String   @db.VarChar(500)
  period      String   @db.VarChar(50)
  periodStart DateTime
  periodEnd   DateTime
  data        String   @db.Text // JSON: full analytics payload
  summary     String?  @db.Text
  generatedBy String?  @db.VarChar(200)
  createdAt   DateTime @default(now())

  @@index([period])
  @@index([periodStart])
  @@index([periodEnd])
  @@map("analytics_snapshots")
}

// ═══════════════════════════════════════════════════════════
// التنسيق المؤسسي (Institutional Coordination)
// ═══════════════════════════════════════════════════════════

model CoordinationTask {
  id           String       @id @default(cuid())
  title        String       @db.VarChar(500)
  description  String?      @db.Text
  assignee     String?      @db.VarChar(200)
  assigneeRole String?      @db.VarChar(200)
  status       TaskStatus   @default(PENDING)
  priority     TaskPriority @default(MEDIUM)
  dueDate      DateTime?
  completedAt  DateTime?
  notes        String?      @db.Text
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  platformId String?
  platform   Platform? @relation(fields: [platformId], references: [id], onDelete: SetNull)
  programId  String?
  program    Program?  @relation(fields: [programId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([priority])
  @@index([assignee])
  @@index([platformId])
  @@index([dueDate])
  @@map("coordination_tasks")
}

enum TaskStatus {
  PENDING // قيد الانتظار
  IN_PROGRESS // قيد التنفيذ
  COMPLETED // مكتمل
  CANCELLED // ملغى
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model DataStandard {
  id              String   @id @default(cuid())
  name            String   @db.VarChar(255)
  slug            String   @unique @db.VarChar(255)
  description     String?  @db.Text
  scope           String   @db.VarChar(100) // beneficiary, enrollment, activity, etc.
  requiredFields  String   @db.Text // JSON array of field names
  validationRules String?  @db.Text // JSON: validation rules
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slug])
  @@index([scope])
  @@index([isActive])
  @@map("data_standards")
}

// ═══════════════════════════════════════════════════════════
// التقييم وضمان الجودة (Evaluation & Quality)
// ═══════════════════════════════════════════════════════════

model Evaluation {
  id              String           @id @default(cuid())
  title           String           @db.VarChar(500)
  evaluator       String           @db.VarChar(200)
  evaluatorRole   String?          @db.VarChar(200) // INTERNAL, EXTERNAL, PEER
  type            EvaluationType   @default(PROGRAM)
  score           Float?
  maxScore        Float            @default(100)
  feedback        String?          @db.Text
  recommendations String?          @db.Text
  status          EvaluationStatus @default(DRAFT)
  evaluatedAt     DateTime         @default(now())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  submittedAt     DateTime?
  approvedAt      DateTime?
  rejectionReason String?          @db.Text

  createdById     String?
  createdBy       AdminUser? @relation("EvaluationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  evaluatorUserId String?
  evaluatorUser   AdminUser? @relation("EvaluationEvaluator", fields: [evaluatorUserId], references: [id], onDelete: SetNull)
  approvedById    String?
  approvedBy      AdminUser? @relation("EvaluationApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  platformId String?
  platform   Platform? @relation(fields: [platformId], references: [id], onDelete: SetNull)
  programId  String?
  program    Program?  @relation(fields: [programId], references: [id], onDelete: SetNull)
  activityId String?
  activity   Activity? @relation(fields: [activityId], references: [id], onDelete: SetNull)
  projectId  String?
  project    Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  impactLogs ImpactLog[]

  @@index([type])
  @@index([status])
  @@index([platformId])
  @@index([programId])
  @@index([createdById])
  @@index([evaluatorUserId])
  @@index([approvedById])
  @@map("evaluations")
}

enum EvaluationType {
  PROGRAM // تقييم برنامج
  ACTIVITY // تقييم نشاط
  PROJECT // تقييم مشروع
  PLATFORM // تقييم منصة
  SELF // تقييم ذاتي
  PEER // تقييم الأقران
}

enum EvaluationStatus {
  DRAFT // مسودة
  FINAL // نهائي (حالة قديمة للتوافق)
  SUBMITTED // مرسل للمراجعة
  APPROVED // معتمد
  REJECTED // مرفوض
}

// ═══════════════════════════════════════════════════════════
// مراحل رحلة المستفيد (Beneficiary Journey Stages)
// ═══════════════════════════════════════════════════════════

model BeneficiaryJourneyStage {
  id            String       @id @default(cuid())
  beneficiaryId String
  beneficiary   Beneficiary  @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  stage         JourneyStage @default(DISCOVERY)
  startedAt     DateTime     @default(now())
  completedAt   DateTime?
  notes         String?      @db.Text
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([beneficiaryId])
  @@index([stage])
  @@map("beneficiary_journey_stages")
}

enum JourneyStage {
  DISCOVERY // اكتشاف
  APPLICATION // تقديم
  ONBOARDING // تأهيل
  ACTIVE // نشط
  ADVANCED // متقدم
  GRADUATED // متخرج
  ALUMNI // خريج/شبكة
  CHAMPION // سفير
}

// ═══════════════════════════════════════════════════════════
// سجل النشاط العام (Audit & Activity Log)
// ═══════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════
// زوار الموقع (Page Visits / Analytics)
// ═══════════════════════════════════════════════════════════

model Visit {
  id         String   @id @default(cuid())
  path       String   @db.VarChar(500)
  visitorId  String?  @db.VarChar(100)
  ipAddress  String?  @db.VarChar(50)
  country    String?  @db.VarChar(100)
  city       String?  @db.VarChar(100)
  region     String?  @db.VarChar(100)
  latitude   Float?
  longitude  Float?
  deviceType String?  @db.VarChar(50) // mobile, desktop, tablet
  browser    String?  @db.VarChar(100)
  os         String?  @db.VarChar(100)
  referrer   String?  @db.VarChar(1000)
  userAgent  String?  @db.Text
  screenSize String?  @db.VarChar(30)
  language   String?  @db.VarChar(20)
  timestamp  DateTime @default(now())

  @@index([timestamp])
  @@index([path])
  @@index([country])
  @@index([visitorId])
  @@map("visits")
}

model ActivityLog {
  id        String   @id @default(cuid())
  entity    String   @db.VarChar(100) // beneficiary, enrollment, platform, etc.
  entityId  String   @db.VarChar(100)
  action    String   @db.VarChar(50) // CREATE, UPDATE, DELETE, etc.
  actor     String?  @db.VarChar(200)
  changes   String?  @db.Text // JSON: {field: {old, new}}
  metadata  String?  @db.Text // JSON: additional context
  createdAt DateTime @default(now())

  @@index([entity])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
}

// ═══════════════════════════════════════════════════════════
// لوحة أثر الرواد (Impact Dashboard)
// نظام النقاط والمستويات والمكافآت والدروع وبوابة العمرة
// ═══════════════════════════════════════════════════════════

// ─── كتالوج أنواع الأنشطة (Activity Types Catalog) ───
// قائمة قابلة للتعديل من الإعدادات، كل نوع له نقاط ومحور

model ImpactAction {
  id        String         @id @default(cuid())
  name      String         @db.VarChar(500) // اسم النشاط
  points    Int // النقاط (قد تكون سالبة للخصومات)
  category  ImpactCategory @default(DIGITAL_ACTIVITY) // المحور
  note      String?        @db.Text
  isActive  Boolean        @default(true)
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  impactLogs ImpactLog[]

  @@index([category])
  @@index([isActive])
  @@index([isActive, sortOrder])
  @@index([isActive, category, sortOrder])
  @@index([category, isActive, sortOrder])
  @@map("impact_actions")
}

enum ImpactCategory {
  DIGITAL_ACTIVITY // النشاط الرقمي
  SCIENTIFIC_EVENTS // المشاركة العلمية والفعاليات
  INITIATIVES // المبادرات والإنتاج
  DISCIPLINE // الالتزام والانضباط
}

// ─── سجل الأنشطة/المساهمات المُدخلة (Impact Log) ───
// كل صف يمثل مساهمة فعلية لعضو

model ImpactLog {
  id              String               @id @default(cuid())
  beneficiaryId   String
  beneficiary     Beneficiary          @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  actionId        String
  action          ImpactAction         @relation(fields: [actionId], references: [id], onDelete: Restrict)
  sourceType      ImpactSourceType     @default(MANUAL)
  sourceId        String?              @db.VarChar(100)
  count           Float                @default(1) // العدد (مثلاً 3 منشورات)
  quality         ImpactQuality        @default(ACCEPTABLE) // مستوى الجودة
  status          ImpactApprovalStatus @default(PENDING_REVIEW) // حالة الاعتماد
  date            DateTime             @default(now())
  link            String?              @db.Text // رابط النشاط (تغريدة، مقال...)
  note            String?              @db.Text
  pointsSnapshot  Int? // النقاط وقت الاعتماد/الاحتساب للتقارير التاريخية
  createdBy       String?              @db.VarChar(200) // من أدخل النشاط
  approvedBy      String?              @db.VarChar(200) // من اعتمد النشاط
  approvedAt      DateTime? // وقت الاعتماد
  rejectionReason String?              @db.Text // سبب الرفض (إلزامي عند الرفض)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  platformId String?
  platform   Platform? @relation(fields: [platformId], references: [id], onDelete: SetNull)

  programId String?
  program   Program? @relation(fields: [programId], references: [id], onDelete: SetNull)

  activityId String?
  activity   Activity? @relation(fields: [activityId], references: [id], onDelete: SetNull)

  enrollmentId String?
  enrollment   Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)

  participationId String?
  participation   Participation? @relation(fields: [participationId], references: [id], onDelete: SetNull)

  reportId String?
  report   SubmittedReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)

  evaluationId String?
  evaluation   Evaluation? @relation(fields: [evaluationId], references: [id], onDelete: SetNull)

  @@unique([sourceType, sourceId, actionId])
  @@index([beneficiaryId])
  @@index([actionId])
  @@index([sourceType])
  @@index([sourceType, sourceId])
  @@index([status])
  @@index([date])
  @@index([platformId])
  @@index([programId])
  @@index([activityId])
  @@index([enrollmentId])
  @@index([participationId])
  @@index([reportId])
  @@index([evaluationId])
  @@index([beneficiaryId, date])
  @@index([beneficiaryId, status, date])
  @@index([platformId, status, date])
  @@index([status, date])
  @@index([actionId, date])
  @@index([beneficiaryId, actionId, date])
  @@index([beneficiaryId, sourceType, sourceId])
  @@map("impact_logs")
}

enum ImpactQuality {
  WEAK // ضعيف (-3)
  ACCEPTABLE // مقبول (0)
  GOOD // جيد (+3)
  EXCELLENT // ممتاز (+6)
  EXCEPTIONAL // استثنائي (+10)
}

enum ImpactApprovalStatus {
  APPROVED // معتمد
  PENDING_REVIEW // قيد المراجعة
  REJECTED // مرفوض
}

enum ImpactSourceType {
  MANUAL
  PARTICIPATION
  ENROLLMENT
  REPORT
  EVALUATION
  EXTERNAL
}

// ─── الدروع والمكافآت (Awards & Rewards) ───

model ImpactAward {
  id            String          @id @default(cuid())
  beneficiaryId String
  beneficiary   Beneficiary     @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  type          ImpactAwardType // درع | مكافأة
  title         String          @db.VarChar(500) // اسم الدرع أو وصف المكافأة
  value         Float           @default(0) // قيمة المكافأة المالية إن وُجدت
  date          DateTime        @default(now())
  note          String?         @db.Text
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([beneficiaryId])
  @@index([type])
  @@index([date])
  @@index([type, date])
  @@index([beneficiaryId, date])
  @@map("impact_awards")
}

enum ImpactAwardType {
  SHIELD // درع
  REWARD // مكافأة مالية
}

// ─── البوابات الشهرية (Monthly Gates) ───
// لكل عضو، لكل شهر: هل اجتاز المهام الإلزامية؟

model ImpactGate {
  id            String      @id @default(cuid())
  beneficiaryId String
  beneficiary   Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  year          Int
  month         Int // 1-12
  passed        Boolean     @default(true)
  createdAt     DateTime    @default(now())

  @@unique([beneficiaryId, year, month])
  @@index([beneficiaryId])
  @@index([year, month])
  @@map("impact_gates")
}

// ─── إعدادات لوحة الأثر (Impact Settings) ───
// صف واحد (id=1) يحوي كل إعدادات النظام بصيغة JSON

model ImpactSettings {
  id           Int      @id @default(1)
  qualityBonus String   @db.Text // JSON: {"WEAK": -3, "ACCEPTABLE": 0, ...}
  levels       String   @db.Text // JSON: [{"name":"عضو جديد","from":0,"to":99}, ...]
  rewardTiers  String   @db.Text // JSON: [{"name":"لا مكافأة","from":0,"to":99}, ...]
  umrah        String   @db.Text // JSON: {"minYearly":3000,"minMonths":9,...}
  updatedAt    DateTime @default(now())

  @@map("impact_settings")
}

// ─── أدلة الحقول المشتركة ───
// يولد Gemini الدليل مرة واحدة ثم يُعاد استخدامه في جميع الخدمات والحسابات.

model FieldHelpGuide {
  id          String   @id @default(cuid())
  service     String   @db.VarChar(100)
  fieldKey    String   @unique @db.VarChar(160)
  label       String   @db.VarChar(200)
  explanation String   @db.Text
  example     String   @db.Text
  tipsJson    String   @db.Text
  source      String   @default("GEMINI") @db.VarChar(30)
  generatedBy String?  @db.VarChar(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([service])
  @@index([service, updatedAt])
  @@map("field_help_guides")
}
