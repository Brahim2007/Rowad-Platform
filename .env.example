# Database (PostgreSQL)
# Use the provider's pooled/PgBouncer connection URL, not the direct database URL.
# Supabase: use the transaction/session pooler host and port.
# Prisma Data Platform/db.prisma.io: keep pgbouncer=true.
ROWAD_DATABASE_URL="postgresql://USER:PASSWORD@POOLER_HOST:5432/rowad_platform?sslmode=require&pgbouncer=true&connection_limit=5&pool_timeout=30"

# Auth
# Generate secret: openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3002"
AUTH_TRUST_HOST=true

# لا تفعّلها إلا إذا كان التطبيق خلف reverse proxy موثوق يحذف رؤوس العميل الأصلية.
TRUST_PROXY_IP_HEADERS=false
# فعّلها فقط عند المرور المباشر عبر Cloudflare.
TRUST_CLOUDFLARE_IP=false

# Development-only admin fallback. Ignored outside NODE_ENV=development.
# DEV_ADMIN_EMAIL="dev-admin@example.test"
# DEV_ADMIN_PASSWORD="replace-with-a-local-only-password"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3002"

# Optional: Email (Nodemailer SMTP)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="smtp-user"
# SMTP_PASS="smtp-password"
# EMAIL_FROM="noreply@rowad-network.org"
